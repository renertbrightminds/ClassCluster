rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Instructors collection ──
    // Each document is keyed by the instructor's Firebase Auth UID.
    match /instructors/{uid} {

      // Any signed-in user can read any instructor profile
      // (needed for the rollup, conflict, and all-instructors views)
      allow read: if request.auth != null;

      // An instructor can update only their own document,
      // and only the availability + availabilityUpdatedAt fields.
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['availability', 'availabilityUpdatedAt', 'dayNotes',
                                   'gradeMin', 'gradeMax', 'levelMin', 'levelMax', 'comment']);

      // Admins (role == "admin") can read and write anything
      allow write: if request.auth != null
                   && get(/databases/$(database)/documents/instructors/$(request.auth.uid)).data.role == "admin";
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
